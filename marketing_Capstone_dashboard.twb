      <aliases enabled='yes' />
      <column aggregation='None' caption='Aggregate rating (bin)' datatype='integer' name='[Aggregate rating (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-1' formula='[Aggregate rating]' peg='0' size='0.5' />
      </column>
      <column datatype='real' name='[Aggregate rating]' role='measure' type='quantitative' />
      <column aggregation='None' caption='Average Cost for two (bin)' datatype='integer' name='[Average Cost for two (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='2' formula='[Average Cost for two]' peg='0' size='200' />
      </column>
      <column datatype='integer' name='[Average Cost for two]' role='measure' type='quantitative' />
      <column caption='Num Cuisines' datatype='integer' name='[Calculation_1454444702740480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LEN([Cuisines]) - LEN(REPLACE([Cuisines], &apos;,&apos;, &apos;&apos;)) + 1' />
      </column>
      <column caption='Cuisine Filter' datatype='string' name='[Calculation_1454444709052417]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Example for Italian&#13;&#10;IF CONTAINS([Cuisines], &quot;Italian&quot;) THEN &quot;Italian&quot; &#13;&#10;ELSEIF CONTAINS([Cuisines], &quot;Continental&quot;) THEN &quot;Continental&quot;&#13;&#10;ELSEIF CONTAINS([Cuisines], &quot;North Indian&quot;) THEN &quot;North Indian&quot;&#13;&#10;// Add more as needed&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Star Restaurant' datatype='string' name='[Calculation_1454445053067266]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Aggregate rating] &gt; 4 &#13;&#10;AND [Votes] &gt; 100 &#13;&#10;AND [Has Online delivery] = &quot;Yes&quot;&#13;&#10;THEN &quot;Star&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Scaled Restaurants ' datatype='real' name='[Calculation_1454445061812231]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([Restaurant ID]) / WINDOW_MAX(COUNT([Restaurant ID]))) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='split cuisines' datatype='string' name='[Calculation_1454445122433036]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPLIT([Cuisines], &apos;,&apos;, 1)' />
